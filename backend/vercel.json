{
  "name": "vinayaka-transport-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "buildCommand": "echo 'Backend built'",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "express",
  "regions": ["iad1", "sfo1", "iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "preview": false
    }
  },
  "env": [
    {
      "key": "DATABASE_URL",
      "type": "secret",
      "description": "PostgreSQL database URL"
    },
    {
      "key": "JWT_SECRET",
      "type": "secret",
      "description": "JWT secret key"
    },
    {
      "key": "REDIS_URL",
      "type": "secret",
      "description": "Redis connection URL"
    }
  ]
}
