NODE_ENV=development

# Backend core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vinayaka_transport
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Auth / JWT
JWT_SECRET=replace_with_at_least_32_characters_random_string
JWT_REFRESH_SECRET=replace_with_another_32_plus_char_random_string
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# OTP behavior
OTP_EXPIRY=10
OTP_LENGTH=6
OTP_MAX_RESEND_PER_WINDOW=5
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_RESEND_WINDOW_MINUTES=10

# OTP provider (required in production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Infrastructure
REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=debug

# Optional integrations
GOOGLE_MAPS_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# Frontend public API base
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_CUSTOMER_API_URL=http://localhost:3001/api/v1

# API service (Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
