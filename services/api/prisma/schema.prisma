generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  COUNTER_STAFF
  DISPATCHER
  RIDER
  ACCOUNTANT
}

enum VehicleType {
  BIKE
  AUTO
  CAR
}

enum RiderStatus {
  OFFLINE
  AVAILABLE
  ON_DELIVERY
}

enum OrderStatus {
  BOOKED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

model User {
  id           String      @id @default(uuid())
  name         String
  phone        String      @unique
  passwordHash String
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  roles        UserRole[]
  rider        Rider?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  audits       AuditLog[]
}

model Role {
  id          String           @id @default(uuid())
  code        RoleCode         @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  roles       RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Branch {
  id         String        @id @default(uuid())
  name       String
  city       String
  latitude   Float
  longitude  Float
  radiusKm   Float
  managerId  String?
  users      User[]
  pricing    PricingRule[]
  orders     Order[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model PricingRule {
  id                String      @id @default(uuid())
  branchId          String
  branch            Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  vehicleType       VehicleType
  baseFare          Decimal     @db.Decimal(10, 2)
  perKmRate         Decimal     @db.Decimal(10, 2)
  minFare           Decimal     @db.Decimal(10, 2)
  commissionPercent Decimal     @db.Decimal(5, 2)
  codEnabled        Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([branchId, vehicleType])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())
  orders    Order[]
}

model Rider {
  id             String        @id @default(uuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType    VehicleType
  vehicleNumber  String
  status         RiderStatus   @default(OFFLINE)
  currentLat     Float?
  currentLng     Float?
  isApproved     Boolean       @default(false)
  deviceBindings RiderDevice[]
  locations      RiderLocation[]
  assignments    DispatchAssignment[]
}

model RiderDevice {
  id        String   @id @default(uuid())
  riderId   String
  rider     Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
  deviceId  String
  ipAddress String?
  createdAt DateTime @default(now())

  @@unique([riderId, deviceId])
}

model RiderLocation {
  id        String   @id @default(uuid())
  riderId   String
  rider     Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  @@index([riderId, createdAt])
}

model Order {
  id                 String               @id @default(uuid())
  trackingNumber     String               @unique
  branchId           String
  branch             Branch               @relation(fields: [branchId], references: [id])
  customerId         String
  customer           Customer             @relation(fields: [customerId], references: [id])
  senderName         String
  senderPhone        String
  receiverName       String
  receiverPhone      String
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  dropAddress        String
  dropLat            Float
  dropLng            Float
  vehicleType        VehicleType
  parcelWeightKg     Float?
  parcelNotes        String?
  fragile            Boolean              @default(false)
  medicine           Boolean              @default(false)
  codRequired        Boolean              @default(false)
  codAmount          Decimal?             @db.Decimal(10, 2)
  estimatedFare      Decimal              @db.Decimal(10, 2)
  finalFare          Decimal              @db.Decimal(10, 2)
  status             OrderStatus          @default(BOOKED)
  etaMinutes         Int?
  qrCodeData         String?
  barcodeData        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  parcel             Parcel?
  events             OrderEvent[]
  assignments        DispatchAssignment[]
  codEntries         CodEntry[]
  complaints         Complaint[]
  custodyEvents      CustodyEvent[]
  notifications      NotificationLog[]
  fraudAlerts        FraudAlert[]

  @@index([branchId, status, createdAt])
}

model Parcel {
  id                 String   @id @default(uuid())
  orderId            String   @unique
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  qrCodePayload      String
  barcodePayload     String
  currentRack        String?
  currentShelf       String?
  currentSlot        String?
  createdAt          DateTime @default(now())
  scans              ParcelScan[]
}

model ParcelScan {
  id        String   @id @default(uuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  scanType  String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([parcelId, createdAt])
}

model DispatchAssignment {
  id         String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId     String
  rider       Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
  assignedBy  String?
  assignedAt  DateTime @default(now())
  acceptedAt  DateTime?

  @@index([riderId, assignedAt])
}

model OrderEvent {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  message   String
  createdAt DateTime    @default(now())

  @@index([orderId, createdAt])
}

model CustodyEvent {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorType String
  actorId   String?
  action    String
  createdAt DateTime @default(now())
}

model CodEntry {
  id              String    @id @default(uuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  expectedAmount  Decimal   @db.Decimal(10, 2)
  collectedAmount Decimal   @db.Decimal(10, 2)
  isSettled       Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

model Settlement {
  id         String    @id @default(uuid())
  branchId   String
  amount     Decimal   @db.Decimal(12, 2)
  closedBy   String
  closedAt   DateTime  @default(now())
}

model Complaint {
  id          String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title        String
  description  String
  status       String   @default("OPEN")
  createdAt    DateTime @default(now())
}

model FraudAlert {
  id          String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  alertType    String
  score        Float
  details      String
  createdAt    DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  resource    String
  resourceId  String?
  ipAddress   String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model NotificationLog {
  id         String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel     String
  recipient   String
  template    String
  status      String
  createdAt   DateTime @default(now())
}
