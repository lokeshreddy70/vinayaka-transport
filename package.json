{
  "name": "vinayaka-transport",
  "version": "1.0.0",
  "private": true,
  "description": "Vinayaka Transport logistics operating system monorepo",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "turbo format",
    "dev:api": "npm run dev --workspace @vinayaka/api",
    "dev:realtime": "npm run dev --workspace @vinayaka/realtime",
    "dev:notifications": "npm run dev --workspace @vinayaka/notifications",
    "dev:admin": "npm run dev --workspace @vinayaka/admin-portal",
    "dev:operations": "npm run dev --workspace @vinayaka/operations-portal",
    "dev:rider": "npm run dev --workspace @vinayaka/rider-portal",
    "dev:tracking": "npm run dev --workspace @vinayaka/tracking-portal"
  },
  "devDependencies": {
    "turbo": "^2.0.12",
    "typescript": "^5.5.4"
  }
}
